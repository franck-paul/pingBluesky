msgid "pingBluesky"
msgstr "pingBluesky"

msgid "Ping Bluesky"
msgstr "Ping Bluesky"

msgid "Bluesky"
msgstr "Bluesky"

msgid "All entries have been ping to Bluesky."
msgstr "Toutes les entrées ont été signalées sur Bluesky."

msgid "No conversion"
msgstr "Pas de conversion"

msgid "Spaces will be removed"
msgstr "Les espaces seront supprimées"

msgid ""
"Spaces will be removed and tag will then be convert to "
"<samp>camelCase</samp>"
msgstr ""
"Les espaces seront supprimées des mots-clés et ils seront convertis en "
"<samp>camelCase</samp>."

msgid ""
"Spaces will be removed and tag will then be convert to "
"<samp>PascalCase</samp>"
msgstr ""
"Les espaces seront supprimées des mots-clés et ils seront convertis en "
"<samp>PascalCase</samp>."

msgid ""
"Spaces will be removed and category name will then be convert to "
"<samp>camelCase</samp>"
msgstr ""
"Les espaces seront supprimées et le nom de la catégorie sera converti en "
"<samp>camelCase</samp>."

msgid ""
"Spaces will be removed and category name will then be convert to "
"<samp>PascalCase</samp>"
msgstr ""
"Les espaces seront supprimées et le nom de la catégorie sera converti en "
"<samp>PascalCase</samp>."

msgid "Activate pingBluesky plugin"
msgstr "Activer le plugin pingBluesky"

#, php-format
msgid "The mandatory cURL library is <strong>%s</strong>."
msgstr "La bibliothèque cURL est <strong>%s</strong>."

msgid "installed and enabled"
msgstr "installée et activée"

msgid "missing or disabled"
msgstr "manquante ou désactivée"

msgid "Bluesky instance:"
msgstr "Instance Bluesky :"

msgid "Account handle:"
msgstr "Compte :"

msgid "Application token:"
msgstr "Jeton applicatif :"

msgid "Status prefix:"
msgstr "Préfixe de statut :"

msgid "Automatic ping"
msgstr "Ping automatique"

msgid "Automatically ping when an entry is first published"
msgstr "Ping automatique à la première publication d'une entrée"

msgid "Restrict automatic ping to one category only"
msgstr "Restreindre le ping automatique à une seule catégorie"

msgid "Category:"
msgstr "Catégorie :"

msgid "List tags as hashtags"
msgstr "Mentionner les mots-clés comme des mots-dièse"

msgid ""
"The tags, inserted as hashtags are currently not recognized on Bluesky."
msgstr ""
"Les mots-clés, insérés en tant que hashtags/mots-dièse, ne sont actuellement"
" pas reconnus sur Bluesky."

msgid "Tags conversion mode:"
msgstr "Mode de conversion des mots-clés :"

msgid "List the names of the categories as hashtags"
msgstr "Mentionner les noms des catégories comme des mots-dièse"

msgid "It will also add the names of the parent categories"
msgstr "Mentionnera également les noms des catégories parentes"

msgid "Categories conversion mode:"
msgstr "Mode de conversion des catégories :"

